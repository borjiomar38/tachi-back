# Compose/runtime
APP_DOMAIN=tachiyomiat.com
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Public client values baked into the frontend during docker build
VITE_BASE_URL=https://tachiyomiat.com
VITE_ENV_NAME=PRODUCTION
VITE_ENV_EMOJI=
VITE_ENV_COLOR=plum
VITE_IS_DEMO=false
VITE_LEMONSQUEEZY_STORE_URL=
VITE_S3_BUCKET_PUBLIC_URL=https://storage.example.com
VITE_GOOGLE_SITE_VERIFICATION=

# Local Postgres container. DATABASE_URL must point at the compose service name.
POSTGRES_DB=tachi_back
POSTGRES_USER=tachi_back
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD
DATABASE_URL=postgresql://tachi_back:CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD@postgres:5432/tachi_back?schema=public

# Auth/session
AUTH_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM
AUTH_SESSION_EXPIRATION_IN_SECONDS=2592000
AUTH_SESSION_UPDATE_AGE_IN_SECONDS=86400
AUTH_ALLOWED_HOSTS=tachiyomiat.com
AUTH_TRUSTED_ORIGINS=https://tachiyomiat.com
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email
EMAIL_SERVER=smtp://user:password@smtp.example.com:587
EMAIL_FROM=Nayovi <contact@nayovi.com>
SUPPORT_EMAIL=contact@nayovi.com
CONTACT_SMTP_SERVER=smtps://contact%40nayovi.com:password@mail.example.com:465
CONTACT_IMAP_SERVER=imaps://contact%40nayovi.com:password@mail.example.com:993
CONTACT_IMAP_MAILBOX=INBOX

# Lemon Squeezy
LEMONSQUEEZY_ENABLED=false
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_TOKENS_STARTER=
LEMONSQUEEZY_VARIANT_TOKENS_PRO=
LEMONSQUEEZY_VARIANT_TOKENS_POWER=

# Hosted OCR/translation providers
GOOGLE_CLOUD_VISION_API_KEY=
GOOGLE_CLOUD_TRANSLATE_API_KEY=
GEMINI_API_KEY=
GEMINI_TRANSLATION_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4.1-mini
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_TRANSLATION_MODEL=claude-3-5-sonnet-latest
OCR_PROVIDER_PRIMARY=google_cloud_vision
TRANSLATION_PROVIDER_PRIMARY=gemini
PROVIDER_REQUEST_TIMEOUT_MS=60000
PROVIDER_RETRY_MAX_ATTEMPTS=2
TRANSLATION_BATCH_MAX_PAYLOAD_CHARS=2000
TRANSLATION_BATCH_MAX_BLOCKS=45
TRANSLATION_BATCH_CONCURRENCY=40
TRANSLATION_BLOCK_RETRY_MAX_ATTEMPTS=3
TRANSLATION_PROMPT_VERSION=2026-05-05.ai-linebreak.v1

# Mobile API
MOBILE_API_ENABLED=true
MOBILE_API_JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM
MOBILE_API_ISSUER=tachi-back
MOBILE_API_AUDIENCE=tachiyomiat
MOBILE_API_ACCESS_TOKEN_TTL_SECONDS=3600
MOBILE_API_REFRESH_TOKEN_TTL_SECONDS=2592000
MOBILE_ANDROID_LATEST_VERSION_CODE=0
MOBILE_ANDROID_LATEST_VERSION_NAME=
MOBILE_ANDROID_MIN_VERSION_CODE=0
MOBILE_ANDROID_RELEASE_URL=
MOBILE_ANDROID_UPDATE_MESSAGE=
MOBILE_ANDROID_UPDATE_URL=

# Logging/storage/jobs
LOGGER_LEVEL=info
LOGGER_PRETTY=false
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_NAME=default
S3_UPLOADS_BUCKET_NAME=uploads
S3_RESULTS_BUCKET_NAME=results
S3_LOGS_BUCKET_NAME=logs
S3_REGION=auto
S3_HOST=s3.example.com
S3_SECURE=true
S3_FORCE_PATH_STYLE=false
JOB_RUNTIME_MODE=inline
JOB_MAX_CONCURRENCY=2
JOB_TOKENS_PER_CHAPTER=10
JOB_MAX_PAGE_BYTES=20000000
JOB_PAGE_UPLOAD_URL_TTL_SECONDS=900
JOB_RESULT_RETENTION_HOURS=24

# Rate limits
CHECKOUT_RATE_LIMIT_MAX_ATTEMPTS=10
CHECKOUT_RATE_LIMIT_WINDOW_SECONDS=300
MOBILE_JOB_CREATE_RATE_LIMIT_MAX_REQUESTS=12
MOBILE_JOB_WRITE_RATE_LIMIT_MAX_REQUESTS=180
MOBILE_JOB_PAGE_UPLOAD_RATE_LIMIT_MAX_REQUESTS=720
MOBILE_JOB_READ_RATE_LIMIT_MAX_REQUESTS=300
MOBILE_JOB_RATE_LIMIT_WINDOW_SECONDS=300
REDEEM_RATE_LIMIT_MAX_ATTEMPTS=10
REDEEM_RATE_LIMIT_WINDOW_SECONDS=300

# Scheduled blog generation
CRON_SECRET=CHANGE_ME_AT_LEAST_16_CHARS_RANDOM
BLOG_GENERATION_ENABLED=true
BLOG_GENERATION_PROVIDER=
BLOG_GENERATION_MODEL=
BLOG_IMAGE_GENERATION_ENABLED=true
BLOG_IMAGE_GENERATION_MODEL=gpt-image-1-mini
BLOG_IMAGE_GENERATION_QUALITY=low
BLOG_IMAGE_GENERATION_SIZE=1536x1024
BLOG_IMAGE_PUBLIC_BASE_URL=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
