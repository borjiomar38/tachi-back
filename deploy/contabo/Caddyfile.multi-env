{$PRODUCTION_APP_DOMAIN} {
	encode zstd gzip
	log {
		output file /var/log/caddy/production-access.log {
			roll_size 100MiB
			roll_keep 20
			roll_keep_for 168h
		}
		format json
	}
	reverse_proxy tachi-production-app:3000
}

{$STAGING_APP_DOMAIN} {
	encode zstd gzip
	log {
		output file /var/log/caddy/staging-access.log {
			roll_size 100MiB
			roll_keep 20
			roll_keep_for 168h
		}
		format json
	}
	reverse_proxy tachi-staging-app:3000
}
