          "width": 226,
          "x": 669,
          "y": 60
        },
        {
          "angle": 0,
          "height": 597,
          "symHeight": 34.06666666666667,
          "symWidth": 44,
          "text": "「 もぉ お おぉ 無理 いひ いいっ ! 」",
