          "width": 240,
          "x": 299,
          "y": 1546
        },
        {
          "angle": 0,
          "height": 110,
          "symHeight": 17.98461538461538,
          "symWidth": 12.88956043956044,
          "text": "WONDERFUL ,  IT'S ALSO  BETTER  THAN  THE HIDDEN  RELIGION .  HIDDEN RELIGION  SOUNDS  QUITE AWKWARD .",
