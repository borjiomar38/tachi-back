        {
          "angle": 0,
          "height": 46,
          "symHeight": 20,
          "symWidth": 18.83333333333333,
          "text": "一边 舔舐 伤口 一边 骂街 呢 。",
          "translation": "يلتقط أنفاسه ويلعن الدنيا.",
          "width": 129,
          "x": 595,
          "y": 712
