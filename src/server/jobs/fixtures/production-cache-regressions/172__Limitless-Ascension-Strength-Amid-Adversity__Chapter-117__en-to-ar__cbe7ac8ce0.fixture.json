    "003__001.jpg": {
      "blocks": [
        {
          "angle": 0,
          "height": 154,
          "symHeight": 13.37714285714286,
          "symWidth": 10.90315757342073,
          "text": "I  WORKED  SO HARD  PREPARING  FOR A  WHOLE  YEAR .  THE  TITLE OF  FLOWER  DEITY  WAS  RIGHT IN  MY  GRASP ,  BUT  IT  WAS SNATCHED  AWAY  BY  SOME UGLY  FREAK  FROM NOWHERE !",
          "translation": "كدتُ طوال عام كامل للاستعداد. لقب إلهة الزهور كان قاب قوسين أو أدنى، لكنه انتُزع مني بواسطة وحش قبيح من العدم!",
          "width": 254,
          "x": 72,
          "y": 588
        },
        {
          "angle": 0,
          "height": 110,
          "symHeight": 19.25,
          "symWidth": 15.0125,
          "text": "OH  MY LITTLE  SWEETIE , PLEASE  STOP CRYING .",
          "translation": "يا حبيبي الصغير، توقفي عن البكاء.",
          "width": 215,
          "x": 222,
          "y": 1822
