    "002__002.jpg": {
      "blocks": [
        {
          "angle": 0,
          "height": 95,
          "symHeight": 18,
          "symWidth": 16.8,
          "text": "PLEASE  CALM DOWN ,  MR .  LU , MISS  MEANT  NO HARM .",
          "translation": "هدئ من روعك يا سيد لو، الآنسة لم تقصد سوءًا.",
          "width": 216,
          "x": 344,
          "y": 0
        },
        {
          "angle": 0,
          "height": 139,
          "symHeight": 19.6,
          "symWidth": 18.80512820512821,
          "text": "ENOUGH NONSENSE ,  WHAT EXACTLY  ARE THESE  ABYSS FRAGMENTS ?",
          "translation": "كفى هراء، ما هي هذه شظايا الهاوية بالضبط؟",
          "width": 254,
          "x": 146,
          "y": 885
        },
        {
          "angle": 0,
          "height": 102,
          "symHeight": 18.5,
          "symWidth": 16.56349206349206,
          "text": "AS  THE  NAME SUGGESTS ,  THEY'RE THE  NINE  KEYS  TO OPEN  IT .",
          "translation": "كما يدل الاسم، إنها المفاتيح التسعة لفتحها.",
          "width": 270,
          "x": 333,
          "y": 1741
        },
        {
          "angle": 0,
          "height": 129,
          "symHeight": 18,
          "symWidth": 16.68579753579753,
          "text": "THIS  IS  THE  10TH REALM ,  AND  THE KEYS  ARE  LOCATED WITHIN  THE  OTHER NINE  REALMS .",
          "translation": "هذا هو العالم العاشر، والمفاتيح تقع داخل العوالم التسعة الأخرى.",
          "width": 268,
          "x": 287,
          "y": 2337
        },
        {
          "angle": 0,
          "height": 103,
          "symHeight": 18.18518518518519,
          "symWidth": 16.77335858585859,
          "text": "WHAT  A  WASTE  OF TIME .  I'M  GOING  TO FIND  THE  OTHER  NINE REALMS  THEN .",
          "translation": "يا له من هدر للوقت. سأبحث إذن عن العوالم التسعة الأخرى.",
          "width": 281,
          "x": 345,
          "y": 2702
        }
      ],
