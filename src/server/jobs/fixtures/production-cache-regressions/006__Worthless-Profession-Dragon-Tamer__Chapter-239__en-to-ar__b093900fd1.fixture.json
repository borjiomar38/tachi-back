          "y": 2056
        },
        {
          "angle": 0,
          "height": 157,
          "symHeight": 17.53333333333333,
          "symWidth": 16.8635989010989,
          "text": "BUT  OVER  TIME , THOSE  SOUTHERN DOGS  ACTUALLY  TRIED TO  SEIZE  CONTROL AND  EVEN  FORMED THEIR  OWN  GANGS",
          "translation": "لكن مع مرور الزمن، حاول أولئك الكلاب الجنوبيون الاستيلاء على السلطة\nوحتى شكّلوا عصاباتهم الخاصة",
          "width": 310,
          "x": 277,
          "y": 2384
        },
        {
          "angle": 0,
          "height": 185,
          "symHeight": 17.88888888888889,
          "symWidth": 17.38222222222222,
          "text": "SO  THE HEAVENLY DRAGON  GANG IS  THE  ONLY DRAGON NATION  GANG HERE ?",
          "translation": "هل عصابة التنين السماوي هي الوحيدة من عصابات أمم التنانين هنا؟",
          "width": 204,
          "x": 120,
          "y": 2711
        },
        {
          "angle": 0,
          "height": 47,
          "symHeight": 17.25,
          "symWidth": 14.41666666666667,
          "text": "YES ...  AND NO .",
          "translation": "نعم... وليس بالتمام.",
