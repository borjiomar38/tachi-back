    "003__001.jpg": {
      "blocks": [
        {
          "angle": 0,
          "height": 82,
          "symHeight": 19.33333333333333,
          "symWidth": 16.79267399267399,
          "text": "PHEW ... I  THOUGHT  YOU'D JUST  LEAVE .",
          "translation": "هممم... ظننتَ أنك ستغادر فقط.",
          "width": 261,
          "x": 254,
          "y": 61
        },
        {
          "angle": 0,
          "height": 158,
          "symHeight": 18.57142857142857,
          "symWidth": 16.92286081099106,
          "text": "OUT  OF  THE  NINE DUNGEONS , ONLY  TWO STILL  HAVE  KEYS - THE OTHER  SEVEN  HAVE  BEEN TAKEN  BY  GANGS  FROM BOTH  NATIONS .",
          "translation": "من بين التسعة أبراج، لا يزال هناك مفتاحان فقط—لقد استولى على السبعة الآخرون عصابات من كلا الأمَتين.",
          "width": 333,
          "x": 127,
          "y": 998
        },
        {
          "angle": 0,
          "height": 79,
          "symHeight": 20,
          "symWidth": 17.89990401755108,
          "text": "YOU  MUST  GATHER ALL  NINE  TO  ENTER ... WHICH  MEANS-",
          "translation": "عليك جمع المفاتيح التسعة كلها للدخول... وهذا يعني—",
          "width": 288,
          "x": 106,
          "y": 2423
        },
        {
          "angle": 0,
          "height": 75,
          "symHeight": 18,
          "symWidth": 17.89285714285714,
          "text": "SO  YOU'LL  TAKE  ME TO  THOSE  SEVEN GANGS ?",
          "translation": "هل ستأخذني إذن إلى تلك العصابات السبعة؟",
          "width": 265,
          "x": 303,
          "y": 2893
        },
        {
          "angle": 0,
          "height": 102,
          "symHeight": 18.4,
          "symWidth": 16.21856209150327,
          "text": "EXACTLY ,  AND  YOU , MR .  LU ,  WILL  HELP  OUR HEAVENLY  DRAGON  GANG ELIMINATE THEM .",
          "translation": "بالضبط، وسيد لو، ستساعد عصابتنا التنين السماوي في القضاء عليهم.",
          "width": 346,
          "x": 92,
          "y": 3939
        }
      ],
      "imgHeight": 4543,
      "imgWidth": 700,
      "sourceLanguage": "en",
      "targetLanguage": "ar",
      "translatorType": "openai"
    },
    "003__002.jpg": {
      "blocks": [
        {
          "angle": 0,
          "height": 106,
          "symHeight": 23.44576719576719,
          "symWidth": 22.61838624338624,
          "text": "DAMN ... SO  THAT'S YOUR  PLAN .",
          "translation": "ملعون... هل هذه خطتك؟",
