    "004.webp": {
      "blocks": [
        {
          "angle": 0,
          "height": 99,
          "symHeight": 20,
          "symWidth": 18.74583333333333,
          "text": "我 刚被 派遣 镇守 的 时候 , 的确 只有 天 命 境界 。",
          "translation": "عندما وُكلت بواجب الحراسة، لم تكن قوتي سوى في مستوى القضاء السماوي.",
