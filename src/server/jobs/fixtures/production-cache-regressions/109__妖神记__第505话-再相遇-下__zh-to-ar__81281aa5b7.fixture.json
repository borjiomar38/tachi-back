    "001.webp": {
      "blocks": [
        {
          "angle": 0,
          "height": 23,
          "symHeight": 23,
          "symWidth": 21.42857142857143,
          "text": "聂 … 你 怎么 了 ?",
          "translation": "نييه... ما خطبك؟",
          "width": 170,
          "x": 230,
          "y": 165
        },
        {
          "angle": 0,
          "height": 87,
          "symHeight": 23.66666666666667,
          "symWidth": 21.46666666666667,
          "text": "我 没事 , 只是 忽然 有点 眩晕 。",
          "translation": "لست بمكروه، فقط شعرت بدوخة مفاجئة.",
          "width": 115,
          "x": 75,
          "y": 632
        },
        {
          "angle": 0,
          "height": 88,
          "symHeight": 23.66666666666667,
          "symWidth": 23.76666666666667,
          "text": "似乎 有 什么 在 拉扯 我 的 意识",
          "translation": "كأن قوة ما تجذب وعيي بعنف.",
          "width": 128,
          "x": 98,
          "y": 783
        },
        {
          "angle": 0,
          "height": 56,
          "symHeight": 23.5,
          "symWidth": 19.83333333333334,
          "text": "赤蟒 ! 赤蟒 ! 又 晕 了 …",
          "translation": "الأفعى الحمراء! الأفعى الحمراء! أعاني من دوار مجدداً...",
          "width": 142,
          "x": 105,
          "y": 1179
        }
      ],
      "imgHeight": 1360,
      "imgWidth": 960,
      "sourceLanguage": "zh",
      "targetLanguage": "ar",
      "translatorType": "openai"
    },
