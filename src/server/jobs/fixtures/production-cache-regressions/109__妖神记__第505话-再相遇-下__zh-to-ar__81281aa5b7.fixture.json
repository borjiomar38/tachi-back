    "003.webp": {
      "blocks": [
        {
          "angle": 0,
          "height": 87,
          "symHeight": 24.5,
          "symWidth": 22.3,
          "text": "这 是 什么 力 量 , 竟能 把 我 拉 进来 ?",
          "translation": "ما هذه القوة التي استطاعت جذبّي إلى هنا؟",
          "width": 129,
          "x": 537,
          "y": 97
        },
        {
          "angle": 0,
          "height": 56,
          "symHeight": 24,
          "symWidth": 21.15,
          "text": "这里 是 , 我 的 识 海 世界 。",
          "translation": "هنا، عالم بحر وعيي.",
          "width": 140,
          "x": 91,
          "y": 147
        },
        {
          "angle": 0,
          "height": 26,
          "symHeight": 24,
          "symWidth": 19,
          "text": "师傅 !",
          "translation": "يا يا معلمي!",
          "width": 60,
          "x": 628,
          "y": 911
        },
        {
          "angle": 0,
          "height": 55,
          "symHeight": 23.5,
          "symWidth": 19.63333333333333,
          "text": "好久不见 , 聂 离 。",
          "translation": "لم نلتق منذ زمن طويل، نييه لي.",
          "width": 113,
          "x": 92,
          "y": 926
        }
      ],
      "imgHeight": 1360,
      "imgWidth": 960,
      "sourceLanguage": "zh",
      "targetLanguage": "ar",
      "translatorType": "openai"
    },
    "004.webp": {
      "blocks": [
        {
          "angle": 0,
          "height": 25,
          "symHeight": 23,
          "symWidth": 19,
          "text": "师傅 !",
          "translation": "يا معلّمي!",
          "width": 61,
          "x": 106,
          "y": 428
        },
        {
          "angle": 0,
          "height": 25,
          "symHeight": 24,
          "symWidth": 20.2,
          "text": "我 好想 你 !",
          "translation": "كم أشتاق إليك!",
          "width": 114,
          "x": 491,
          "y": 445
        },
        {
          "angle": 0,
          "height": 87,
          "symHeight": 23.25,
          "symWidth": 21.25,
          "text": "傻 孩子 , 活 了 两 辈子 了 , 还 是 这般 模样 。",
          "translation": "يا له من طفل ساذج، عشت عمرين وما زلت على هذه الحال.",
          "width": 157,
          "x": 84,
          "y": 622
        },
        {
          "angle": 0,
          "height": 35,
          "symHeight": 29,
          "symWidth": 25.33333333333333,
          "text": "聂 离 。",
          "translation": "نيي لي.",
          "width": 66,
          "x": 500,
          "y": 951
        },
        {
          "angle": 0,
          "height": 88,
          "symHeight": 23.66666666666667,
          "symWidth": 21.5,
          "text": "我 通过 一缕 意念 与 你 沟通 , 时间 有限 , 你 听 我 说 。",
          "translation": "أتواصل معك عبر خيط من الفكر، والزمان ضيق، فأصغِ إلي.",
          "width": 192,
          "x": 670,
          "y": 1160
        },
        {
          "angle": 0,
          "height": 54,
          "symHeight": 23,
          "symWidth": 20.9,
          "text": "师傅 已经 不 在 了 。",
          "translation": "لم يعد المعلم بيننا.",
          "width": 130,
          "x": 301,
          "y": 1192
        }
      ],
      "imgHeight": 1360,
      "imgWidth": 960,
      "sourceLanguage": "zh",
      "targetLanguage": "ar",
      "translatorType": "openai"
    },
    "005.webp": {
      "blocks": [
        {
          "angle": 0,
          "height": 87,
          "symHeight": 24.33333333333333,
          "symWidth": 22,
          "text": "有 一股 强大 的 意 念 , 已经 慢慢 注 意 到 了 你 的 存在 。",
          "translation": "هناك فكرة عاتية، بدأت تدريجياً تُدرك وجودك.",
          "width": 191,
          "x": 584,
          "y": 85
        },
        {
          "angle": 0,
          "height": 119,
          "symHeight": 23.5,
          "symWidth": 22.29285714285714,
          "text": "它 的 力量 远超 你 的 想象 ,  若是 被 它 盯上 , 后果 不堪设想 。",
          "translation": "قوتها تفوق خيالك، وإن وقعت تحت نظرها، فالنتيجة لا تُحتمل.",
          "width": 190,
          "x": 699,
          "y": 467
        },
        {
          "angle": 0,
          "height": 25,
          "symHeight": 25,
          "symWidth": 19.33333333333333,
          "text": "师傅 , 您 说 。",
          "translation": "يا معلّمي، ماذا تقول؟",
          "width": 141,
          "x": 94,
          "y": 469
        },
        {
          "angle": 0,
          "height": 88,
          "symHeight": 24.11111111111111,
          "symWidth": 21.05555555555556,
          "text": "师傅 , 这 意念 是 什么 , 你 可 知道 ?",
          "translation": "يا معلّمي، هل تعرف ما هذه الفكرة؟",
          "width": 157,
          "x": 392,
          "y": 677
        },
        {
          "angle": 0,
          "height": 55,
          "symHeight": 23,
          "symWidth": 21.41666666666667,
          "text": "具体 是 什么 , 我 也 不清楚 。",
          "translation": "لست أدري على وجه التحديد ما هي.",
          "width": 140,
          "x": 106,
          "y": 1043
        },
        {
          "angle": 0,
          "height": 86,
          "symHeight": 24,
          "symWidth": 22.06666666666667,
          "text": "不过 , 我 也 坚持 不了 多 久 , 你 必须",
          "translation": "لكن لن أستطيع الصمود طويلاً، يجب عليك",
          "width": 132,
          "x": 736,
          "y": 1148
        },
        {
          "angle": 0,
          "height": 87,
          "symHeight": 24,
          "symWidth": 21.96190476190476,
          "text": "但 我 可以 施展 秘 法 , 暂时 屏蔽 它 的 感知 。",
          "translation": "ولكن يمكنني أن أُحيل سحرًا يكتم إدراكها لحينٍ مؤقت.",
          "width": 185,
          "x": 195,
          "y": 1154
        }
      ],
      "imgHeight": 1360,
      "imgWidth": 960,
      "sourceLanguage": "zh",
      "targetLanguage": "ar",
      "translatorType": "openai"
    },
    "006.webp": {
      "blocks": [
        {
          "angle": 0,
          "height": 117,
          "symHeight": 23.5,
          "symWidth": 20.61111111111111,
