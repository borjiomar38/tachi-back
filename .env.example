VITE_PORT=3000

# DOCKER
DOCKER_DATABASE_PORT="5432"
DOCKER_DATABASE_NAME="tachi-back"
DOCKER_DATABASE_USERNAME="tachi-back"
DOCKER_DATABASE_PASSWORD="tachi-back"

DOCKER_MINIO_API_PORT="9000"
DOCKER_MINIO_UI_PORT="9001"
DOCKER_MINIO_USERNAME="minioadmin"
DOCKER_MINIO_PASSWORD="minioadmin"

DOCKER_MAILDEV_SMTP_PORT="1025"
DOCKER_MAILDEV_UI_PORT="1080"

# BASE URL
VITE_BASE_URL="http://localhost:${VITE_PORT}"
# Optional Google Search Console verification token.
# VITE_GOOGLE_SITE_VERIFICATION=""

# S3
# S3_BUCKET_NAME is kept as a legacy generic/public bucket for starter-compatible helpers.
S3_BUCKET_NAME="default"
S3_UPLOADS_BUCKET_NAME="uploads"
S3_RESULTS_BUCKET_NAME="results"
S3_LOGS_BUCKET_NAME="logs"
S3_HOST="127.0.0.1:${DOCKER_MINIO_API_PORT}"
S3_ACCESS_KEY_ID="tachi-back-access-key"
S3_SECRET_ACCESS_KEY="tachi-back-secret-key"
S3_SECURE=false
S3_FORCE_PATH_STYLE=true
VITE_S3_BUCKET_PUBLIC_URL="http://${S3_HOST}/${S3_BUCKET_NAME}"

# Use the following environment variables to show the environment name.
VITE_ENV_NAME="LOCAL"
VITE_ENV_EMOJI="🚧"
VITE_ENV_COLOR="gold"

# Configure demo mode (read only)
VITE_IS_DEMO="false"

# DATABASE
DATABASE_URL="postgres://${DOCKER_DATABASE_USERNAME}:${DOCKER_DATABASE_PASSWORD}@localhost:${DOCKER_DATABASE_PORT}/${DOCKER_DATABASE_NAME}"

# AUTH
AUTH_SECRET="REPLACE ME" # You can use `npx @better-auth/cli@latest secret` to a generated secret
# AUTH_ALLOWED_HOSTS="*.vercel.app" # Comma-separated list of allowed hosts for dynamic base URL (https://better-auth.com/docs/concepts/dynamic-base-url)
AUTH_SESSION_EXPIRATION_IN_SECONDS=2592000 # 30 days
AUTH_SESSION_UPDATE_AGE_IN_SECONDS=86400 # 1 day (every 1 day the session expiration is updated)
# AUTH_TRUSTED_ORIGINS="https://admin.example.com,https://staging-admin.example.com" # Optional: trusted web admin origins for Better Auth

# GITHUB
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# PAYMENTS
LEMONSQUEEZY_ENABLED="false"
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
LEMONSQUEEZY_STORE_ID=""
VITE_LEMONSQUEEZY_STORE_URL=""
LEMONSQUEEZY_VARIANT_TOKENS_STARTER=""
LEMONSQUEEZY_VARIANT_TOKENS_PRO=""
LEMONSQUEEZY_VARIANT_TOKENS_POWER=""

# PROVIDERS
GOOGLE_CLOUD_VISION_API_KEY=""
GOOGLE_CLOUD_TRANSLATE_API_KEY=""
GEMINI_API_KEY=""
GEMINI_TRANSLATION_MODEL="gemini-2.5-flash"
OPENAI_API_KEY=""
OPENAI_TRANSLATION_MODEL="gpt-4.1-mini"
OPENROUTER_API_KEY=""
ANTHROPIC_API_KEY=""
ANTHROPIC_TRANSLATION_MODEL="claude-3-5-sonnet-latest"
OCR_PROVIDER_PRIMARY="google_cloud_vision"
TRANSLATION_PROVIDER_PRIMARY="gemini"
PROVIDER_REQUEST_TIMEOUT_MS=60000
PROVIDER_RETRY_MAX_ATTEMPTS=2
TRANSLATION_PROMPT_VERSION="2026-03-20.v1"

# BLOG + CRON
# Set this in production so Vercel Cron sends Authorization: Bearer $CRON_SECRET.
CRON_SECRET=""
BLOG_GENERATION_ENABLED="true"
# Optional: anthropic, gemini, or openai. Defaults to TRANSLATION_PROVIDER_PRIMARY.
BLOG_GENERATION_PROVIDER=""
BLOG_GENERATION_MODEL=""
BLOG_IMAGE_GENERATION_ENABLED="true"
BLOG_IMAGE_GENERATION_MODEL="gpt-image-2"
BLOG_IMAGE_GENERATION_QUALITY="low"
# Optional override. Defaults to VITE_S3_BUCKET_PUBLIC_URL.
BLOG_IMAGE_PUBLIC_BASE_URL=""

# MOBILE API
MOBILE_API_ENABLED="false"
MOBILE_API_JWT_SECRET=""
MOBILE_API_ISSUER="tachi-back"
MOBILE_API_AUDIENCE="tachiyomiat"
MOBILE_API_ACCESS_TOKEN_TTL_SECONDS=3600
MOBILE_API_REFRESH_TOKEN_TTL_SECONDS=2592000

# EMAILS
EMAIL_SERVER="smtp://0.0.0.0:${DOCKER_MAILDEV_SMTP_PORT}"
EMAIL_FROM="Tachiyomi Back <noreply@example.com>"

# JOBS
JOB_RUNTIME_MODE="inline"
JOB_MAX_CONCURRENCY=2
JOB_TOKENS_PER_CHAPTER=10
JOB_MAX_PAGE_BYTES=20000000
JOB_PAGE_UPLOAD_URL_TTL_SECONDS=900
JOB_RESULT_RETENTION_HOURS=24
CHECKOUT_RATE_LIMIT_MAX_ATTEMPTS=10
CHECKOUT_RATE_LIMIT_WINDOW_SECONDS=300
MOBILE_JOB_CREATE_RATE_LIMIT_MAX_REQUESTS=12
MOBILE_JOB_WRITE_RATE_LIMIT_MAX_REQUESTS=180
MOBILE_JOB_READ_RATE_LIMIT_MAX_REQUESTS=300
MOBILE_JOB_RATE_LIMIT_WINDOW_SECONDS=300
REDEEM_RATE_LIMIT_MAX_ATTEMPTS=10
REDEEM_RATE_LIMIT_WINDOW_SECONDS=300

# LOGGER
LOGGER_LEVEL="info"
LOGGER_PRETTY="true"

# OBSERVABILITY
SENTRY_DSN=""
OTEL_EXPORTER_OTLP_ENDPOINT=""
