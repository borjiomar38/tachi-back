{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm db:migrate:deploy && pnpm build",
  "crons": [
    {
      "path": "/api/cron/generate-blog-article",
      "schedule": "0 1 * * *"
    }
  ],
  "framework": null,
  "installCommand": "pnpm install",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "translate-manhwa-ai.com"
        }
      ],
      "destination": "https://tachiyomiat.com/translate-manhwa-ai",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.translate-manhwa-ai.com"
        }
      ],
      "destination": "https://tachiyomiat.com/translate-manhwa-ai",
      "statusCode": 301
    }
  ]
}
